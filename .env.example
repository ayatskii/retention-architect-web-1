# ═══════════════════════════════════════════════
# Wins Retention Architect — Environment Template
# ───────────────────────────────────────────────
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ═══════════════════════════════════════════════

# ── Backend API ──────────────────────────────────
# URL of the FastAPI backend (defaults to localhost in dev)
VITE_API_URL=http://localhost:8000

# ── OpenAI Integration ───────────────────────────
# Get your key at https://platform.openai.com/api-keys
# If left blank or set to the placeholder, WinsAI runs in mock mode.
VITE_OPENAI_API_KEY=your_key_here
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_OPENAI_MAX_TOKENS=200

# ── App Meta ─────────────────────────────────────
VITE_APP_NAME=Wins Intelligence Hub
