# ═══════════════════════════════════════════════════
# Wins Intelligence Hub — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── OpenAI (Wins AI Chat Widget) ──────────────────
# Obtain your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-proj-...

# Model to use for Wins AI responses
# Options: gpt-4o | gpt-4o-mini | gpt-4-turbo
VITE_OPENAI_MODEL=gpt-4o-mini

# Max tokens per AI response (keep low for chat speed)
VITE_OPENAI_MAX_TOKENS=200

# ── App Config ────────────────────────────────────
VITE_APP_NAME=Wins Intelligence Hub
VITE_APP_VERSION=3.0.0
